# AgentWeave runtime configuration
#
# Copy this file to .env and fill in your own OpenAI-compatible endpoints.
# Do not commit .env.

OPENAI_API_KEY=not-needed

# Orchestrator model
QWEN36_BASE_URL=http://localhost:8000/v1
QWEN36_MODEL=openai-compatible-chat-model
QWEN36_MAX_TOKENS=8192
QWEN36_CONTEXT_WINDOW=32768

# SQL generation / worker model
QWEN32_BASE_URL=http://localhost:8001/v1
QWEN32_MODEL=openai-compatible-sql-model
QWEN32_MAX_TOKENS=2048
QWEN32_CONTEXT_WINDOW=32768

# Memory embedding model
EMBEDDING_BASE_URL=http://localhost:8002/v1
EMBEDDING_MODEL=openai-compatible-embedding-model
MEMORY_EMBEDDING_ENABLED=1

# Optional vision worker profile
QWEN_VL_BASE_URL=http://localhost:8003/v1
QWEN_VL_MODEL=openai-compatible-vision-model
QWEN_VL_MAX_TOKENS=4096
QWEN_VL_CONTEXT_WINDOW=32768

# Memory / runtime switches
MEMORY_ENABLED=1
TEXT2SQL_TIMEZONE=Asia/Hong_Kong
OPENAI_CLIENT_TIMEOUT=60
OPENAI_CLIENT_MAX_RETRIES=2

# Database backend
# CSV mode expects you to provide local data files. Data files are ignored by git.
TEXT2SQL_BACKEND=csv
TEXT2SQL_TABLES_JSON={"resources":"data/resources.csv","sea_cable_faults":"data/sea_cable_faults.csv"}

# SQLite mode example:
# TEXT2SQL_BACKEND=sqlite
# TEXT2SQL_DATABASE_URL=sqlite:////absolute/path/to/database.db

# Result store
SQL_RESULT_SAMPLE_ROWS=50
SQL_RESULT_STORE_MAX_ROWS=1000
SQL_RESULT_CELL_MAX_CHARS=300
# SQL_RESULT_TTL_HOURS=24

# HTTP/SSE backend server
AGENTWEAVE_SERVER_HOST=127.0.0.1
AGENTWEAVE_SERVER_PORT=8765
AGENTWEAVE_SERVER_TOKEN=dev-token
AGENTWEAVE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AGENTWEAVE_RUN_CACHE_MAX=1000
AGENTWEAVE_RUN_CACHE_TTL_SECONDS=21600
